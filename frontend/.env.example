# Template for frontend/.env — used for non-Docker local runs (copy to frontend/.env).
# Under Docker Compose these are provided by the `frontend` service environment instead.
# frontend/.env is git-ignored.

# Server-side address of the Symfony API the BFF proxies to.
API_INTERNAL_URL=http://localhost:8000

# Public origin (adapter-node CSRF/redirect origin checks).
ORIGIN=http://localhost:5173

# Sentry browser + SSR monitoring. Leave empty to keep Sentry disabled (no-op).
# The DSN is safe to expose to the browser; paste your project DSN to enable:
#   PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_ENVIRONMENT=development
