# Secrets — never commit (SSDLC: secrets out of code).
# The real backend/.env is git-ignored; commit backend/.env.example instead and
# `cp backend/.env.example backend/.env` for local setup.
backend/.env
.env.local
.env.*.local
backend/.env.local
backend/.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# JWT signing keys (generated per environment, never committed)
backend/config/jwt/*.pem

# PHP / Symfony
backend/vendor/
backend/var/
/backend/.phpunit.cache/

# Node / SvelteKit
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/
frontend/.vercel/
frontend/.wrangler/

# OS / editor
.DS_Store
*.log
