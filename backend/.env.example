# Template for backend/.env — COPY this to backend/.env and fill in real values.
#   cp backend/.env.example backend/.env
#
# backend/.env is git-ignored so no secrets are ever committed (SSDLC: secrets out of code).
# In production these are provided as encrypted env vars by DigitalOcean / Cloudflare.

###> symfony/framework-bundle ###
APP_ENV=dev
# Generate one with:  php -r 'echo bin2hex(random_bytes(16));'
APP_SECRET=CHANGE_ME_dev_secret
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> ssdlc-bank app config ###
# Risk thresholds (minor units / counts). Amount in cents.
RISK_MFA_THRESHOLD_CENTS=1000000
RISK_MAX_PAYMENTS_PER_MINUTE=3
# Comma-separated origins the BFF is allowed to call from (defense in depth; BFF is same-origin in prod).
TRUSTED_BFF_ORIGINS=http://localhost:5173
# From address for outgoing mail (MFA codes, notifications).
MAILER_FROM="SSDLC Bank <no-reply@bank-demo.example.com>"
# How long an emailed MFA code stays valid.
MFA_CODE_TTL_SECONDS=300
###< ssdlc-bank app config ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Must match the passphrase used to generate config/jwt/*.pem (the entrypoint generates
# the keypair with this value on first boot). Change it for your environment.
JWT_PASSPHRASE=CHANGE_ME_dev_passphrase
###< lexik/jwt-authentication-bundle ###

###> symfony/lock ###
LOCK_DSN=flock
###< symfony/lock ###

###> symfony/messenger ###
# Doctrine-backed broker queue consumed by the worker container.
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=1
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
# Default points at the Docker Compose "db" service. For host-side commands, override with 127.0.0.1.
DATABASE_URL="postgresql://app:app@db:5432/ssdlc_bank?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# Local: overridden by Docker Compose to smtp://mailpit:1025.
# Production: postmark+api://<POSTMARK_API_TOKEN>@default
MAILER_DSN=null://null
###< symfony/mailer ###
